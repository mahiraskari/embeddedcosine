# ── Claude Code ──────────────────────────────────────────
.claude/

# ── Python ───────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache
.Python
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Environment / secrets ─────────────────────────────────
.env
.env.local
.env.*.local
# .env.example is committed on purpose — it has no real values

# ── Data files (often large, not source code) ─────────────
data/*.csv
data/*.json
data/*.parquet
data/*.sqlite
data/*.db

# ── Generated files (embeddings, indexes) — reproducible, not source code ─────
*.faiss
*.index
*.npy

# ── All backend data except the demo dataset ──────────────────────────────────
backend/data/uploads/
backend/data/projects/
backend/data/config*.json
backend/data/uploaded_file.*

# ── But keep the demo dataset — needed for the landing page ───────────────────
!backend/data/demo/
!backend/data/demo/*.npy
!backend/data/demo/*.faiss
!backend/data/demo/meta.json

# ── Model cache (downloaded by sentence-transformers) ─────
backend/model_cache/
.cache/

# ── Frontend build artifacts ──────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ── IDE / OS ──────────────────────────────────────────────
.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
desktop.ini
