__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache
.Python
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Environment / secrets ─────────────────────────────────
