# ── Data files (often large, not source code) ─────────────
data/*.csv
data/*.json
data/*.parquet
data/*.sqlite
data/*.db

# ── Vector index files (generated, large) ─────────────────
*.faiss
*.index
backend/indexes/

# ── Model cache (downloaded by sentence-transformers) ─────
backend/model_cache/
.cache/

