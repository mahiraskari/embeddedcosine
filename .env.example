# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
# .env.example IS committed — it documents what variables are needed.

# If you ever use the HuggingFace Hub API (optional, not needed for basic usage)
# HUGGINGFACE_TOKEN=your_token_here

# Backend server settings (defaults are fine for local dev)
# BACKEND_HOST=localhost
# BACKEND_PORT=8000

# CORS origin for frontend (default: local Vite dev server)
# FRONTEND_ORIGIN=http://localhost:5173
